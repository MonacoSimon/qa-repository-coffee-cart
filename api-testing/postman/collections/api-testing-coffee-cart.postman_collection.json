            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Es HTML\", function () {",
                  "    pm.expect(pm.response.headers.get(\"Content-Type\"))",
                  "        .to.include(\"text/html\");",
                  "});",
                  "",
                  "pm.test(\"Contiene formulario de reset\", function () {",
                  "pm.expect(pm.response.text()).to.include(\"cart\");",
                  "});",
                  "",
                  "pm.test(\"La respuesta contiene contenido esperado\", function () {",
                  "    pm.expect(pm.response.text()).to.include(\"Coffee cart\");",
                  "});",
                  "",
                  "pm.test(\"Tiempo de respuesta aceptable\", function () {",
                  "pm.expect(pm.response.responseTime).to.be.below(2000);",
                  "});",
                  "",
                  "",
                  "pm.test(\"La respuesta no está vacía\", function () {",
                  "pm.expect(pm.response.text().length).to.be.above(0);",
                  "});",
                  ""
